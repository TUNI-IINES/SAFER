<?xml version="1.0" ?>
<model>
  <name>anafi4k</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>Drone Surveillance Hackathon</name>
    <email></email>
  </author>

  <description>
    Parrot Anafi 4K — simplified Gazebo simulation model.

    Topics published (mirrors anafi_ros real-drone topics):
      /anafi/image        sensor_msgs/Image        @ 30 Hz
      /anafi/camera_info  sensor_msgs/CameraInfo   @ 30 Hz
      /anafi/odometry     nav_msgs/Odometry        @ 50 Hz

    The model hovers at its spawn height (gravity disabled on base_link).
    Move it during testing via:
      ros2 service call /gazebo/set_entity_state \
        gazebo_msgs/srv/SetEntityState \
        "{state: {name: anafi4k, pose: {position: {x: 0, y: -3.5, z: 1.5}}}}"
  </description>
</model>
