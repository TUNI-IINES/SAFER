          <pose>0.9848 -2.9132 0.04 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.045</radius>
              <length>0.025</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.02 0.55 1.00 1</ambient>
            <diffuse>0.02 0.55 1.00 1</diffuse>
            <emissive>0.00 0.08 0.20 1</emissive>
          </material>
        </visual>
        <visual name="ellipse_dot_03">
          <cast_shadows>false</cast_shadows>
          <pose>0.9659 -2.8706 0.04 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.045</radius>
              <length>0.025</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.02 0.55 1.00 1</ambient>
            <diffuse>0.02 0.55 1.00 1</diffuse>
            <emissive>0.00 0.08 0.20 1</emissive>
          </material>
        </visual>
        <visual name="ellipse_dot_04">
